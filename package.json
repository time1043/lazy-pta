{
  "name": "lazy-pta",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "data:down": "find ./data/workspace -type f \\( -name \"*clean*\" -o -name \"*.md\" -o -name \"*-submit.json\" \\) -delete",
    "data:down:ai-submit": "find ./data/workspace -type f -name \"*-ai-submit.json\" -delete",
    "data:down:get-submit": "find ./data/workspace -type f -name \"*-get-submit.json\" -delete",
    "data:down:submit": "find ./data/workspace -type f -name \"*-submit.json\" -delete",
    "data:up": "pnpm dev",
    "dev": "tsc --noEmit && dotenvx run -- tsx watch src/main.ts",
    "env:gen": "sed 's/=.*/=/' .env > .env.example",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "pta:answer-ai-submit": "dotenvx run -- playwright test answer-ai-submit.spec.ts",
    "pta:answer-get": "dotenvx run -- playwright test answer-get.spec.ts",
    "pta:answer-get-submit": "dotenvx run -- playwright test answer-get-submit.spec.ts",
    "pta:login": "dotenvx run -- playwright test login.spec.ts",
    "pta:question-get": "dotenvx run -- playwright test question-get.spec.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.65.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.48.0"
  },
  "packageManager": "pnpm@10.18.0"
}
